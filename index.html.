<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CongoCash • DRC CreditManager</title>
  <!-- Font Awesome 6 (free) for icons & checkmark -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts: Inter (sans-serif) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #0F1219;  /* deep charcoal base */
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      color: #EDF2F7;
      padding: 2rem 1.5rem;
      line-height: 1.5;
    }

    h1 {
      font-weight: 600;
      font-size: 2.2rem;
      letter-spacing: -0.02em;
      margin-bottom: 0.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    h1 span {
      background: #1F2A3F;
      color: #60A5FA;
      font-size: 1rem;
      font-weight: 500;
      padding: 0.3rem 1rem;
      border-radius: 40px;
      letter-spacing: normal;
    }
    .subhead {
      color: #8F9EB5;
      margin-bottom: 2.5rem;
      border-left: 4px solid #2F80ED;
      padding-left: 1rem;
      font-weight: 400;
    }

    /* pages grid – each card is a distinct page */
    .pages-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
    }

    .page-card {
      background: #1E2430;        /* charcoal card background */
      border-radius: 24px;         /* slightly larger outer radius, inner elements 8px */
      box-shadow: 0 18px 30px -12px rgba(0, 0, 0, 0.7), 0 4px 8px rgba(0, 40, 80, 0.3);
      padding: 1.8rem 1.8rem 2.2rem;
      width: 400px;
      min-width: 340px;
      flex: 1 1 380px;
      transition: transform 0.1s ease;
      border: 1px solid #2D3748;
    }

    .page-card h2 {
      font-size: 1.3rem;
      font-weight: 500;
      color: #B4C6E0;
      margin-bottom: 1.8rem;
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px dashed #334155;
      padding-bottom: 0.75rem;
    }
    .page-card h2 i {
      color: #2F80ED;
      font-size: 1.3rem;
      width: 1.8rem;
    }

    /* all inputs, selects, textareas */
    input, select, textarea, .fake-input {
      background-color: #2B313E;
      border: 1px solid #3F4A5A;
      border-radius: 8px;          /* consistent 8px radius */
      padding: 0.8rem 1rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      color: #F0F6FC;
      width: 100%;
      outline: none;
      transition: border 0.1s, box-shadow 0.2s;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
    }
    input:focus, select:focus, textarea:focus {
      border-color: #2F80ED;
      box-shadow: 0 0 0 3px rgba(47, 128, 237, 0.3);
    }
    ::placeholder {
      color: #7388A3;
      opacity: 0.7;
    }

    /* buttons */
    .btn {
      background: #2F80ED;
      border: none;
      border-radius: 8px;
      padding: 0.9rem 1.8rem;
      font-weight: 600;
      font-size: 1rem;
      color: white;
      width: 100%;
      cursor: default;      /* static demo, but pointer if you like */
      box-shadow: 0 8px 16px -6px #0e2a4a;
      transition: background 0.1s;
      letter-spacing: 0.3px;
      border: 1px solid #4791f0;
    }
    .btn-small {
      background: #253141;
      color: #CBD5E0;
      box-shadow: none;
      font-weight: 500;
      padding: 0.5rem 1.2rem;
      width: auto;
      border: 1px solid #40536b;
    }
    .btn i {
      margin-right: 8px;
    }

    /* sliders */
    .slider-group {
      margin: 1.5rem 0;
    }
    .slider-label {
      display: flex;
      justify-content: space-between;
      margin-bottom: 6px;
      color: #B0C2DA;
    }
    input[type=range] {
      width: 100%;
      height: 6px;
      background: #334153;
      border-radius: 10px;
      -webkit-appearance: none;
      appearance: none;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      background: #2F80ED;
      border-radius: 20px;
      box-shadow: 0 2px 10px #1f4c99;
      cursor: default;
      border: 2px solid white;
    }

    /* progress bar simulation */
    .progress {
      background: #293141;
      height: 8px;
      border-radius: 20px;
      margin-bottom: 1.8rem;
      position: relative;
    }
    .progress-fill {
      width: 33%;
      height: 8px;
      background: #2F80ED;
      border-radius: 20px;
    }
    .step-text {
      font-size: 0.85rem;
      color: #96A9C7;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }

    /* phone input with country code */
    .phone-wrapper {
      display: flex;
      align-items: center;
      background-color: #2B313E;
      border: 1px solid #3F4A5A;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
    }
    .phone-prefix {
      background: #1F2937;
      padding: 0.8rem 0.8rem 0.8rem 1.2rem;
      font-weight: 500;
      color: #BBD2F0;
      border-right: 1px solid #40536b;
      font-size: 1rem;
      white-space: nowrap;
    }
    .phone-wrapper input {
      border: none;
      border-radius: 0 8px 8px 0;
      box-shadow: none;
      background: transparent;
    }
    .phone-wrapper input:focus {
      box-shadow: none;
      border-color: transparent;
    }

    /* summary card inside page 4 */
    .summary-box {
      background: #1A212C;
      border-radius: 12px;
      padding: 1.2rem 1.5rem;
      margin-top: 1.8rem;
      border-left: 6px solid #2F80ED;
      font-size: 0.95rem;
      box-shadow: inset 0 0 0 1px #2F4058;
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 0.4rem 0;
      border-bottom: 1px dashed #2F4058;
    }
    .summary-row:last-child {
      border-bottom: none;
    }
    .summary-label {
      color: #9BB1D0;
    }
    .summary-value {
      font-weight: 500;
      color: #E9F0FA;
    }

    /* admin table */
    .admin-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      gap: 1rem;
    }
    .search-wrapper {
      display: flex;
      gap: 0.5rem;
      flex: 1;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    th {
      text-align: left;
      padding: 0.7rem 0.5rem;
      color: #A6C0E0;
      font-weight: 500;
      border-bottom: 1px solid #35455C;
    }
    td {
      padding: 0.7rem 0.5rem;
      border-bottom: 1px solid #2A3548;
    }
    .status-badge {
      background: #2F3B4E;
      padding: 0.25rem 0.8rem;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 500;
      display: inline-block;
      color: #C0D4F5;
    }
    .status-badge.approved {
      background: #1E4A2F;
      color: #A5F0B5;
    }

    /* green checkmark big */
    .success-check {
      font-size: 5rem;
      color: #27AE60;
      text-align: center;
      margin: 1rem 0 0.5rem;
      filter: drop-shadow(0 6px 8px #0f3f1f);
    }
    .ref-number {
      background: #262F3E;
      padding: 0.7rem;
      border-radius: 40px;
      font-family: monospace;
      font-size: 1.2rem;
      letter-spacing: 2px;
      text-align: center;
      margin: 1.5rem 0;
    }

    /* spacing */
    .form-row {
      margin-bottom: 1.3rem;
    }
    .two-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .mt-3 {
      margin-top: 1.5rem;
    }
    .text-center {
      text-align: center;
    }
    i {
      color: #2F80ED;
    }
  </style>
</head>
<body>
  <h1>🇨🇩 CongoCash <span>DRC CreditManager</span></h1>
  <div class="subhead">7‑page fintech UI · deep charcoal & vibrant blue · +243 localised</div>

  <div class="pages-grid">
    <!-- PAGE 1 – Interactive Calculator -->
    <div class="page-card">
      <h2><i class="fas fa-calculator"></i> Page 1 · Loan calculator</h2>
      <div class="calculator-widget">
        <div class="slider-group">
          <div class="slider-label"><span>Loan amount</span> <span id="amountVal">$5,000</span></div>
          <input type="range" id="amountSlider" min="200" max="10000" value="5000" step="100">
        </div>
        <div class="slider-group">
          <div class="slider-label"><span>Loan term (months)</span> <span id="termVal">30 months</span></div>
          <input type="range" id="termSlider" min="6" max="60" value="30" step="1">
        </div>
        <div style="background: #1F2A38; border-radius: 12px; padding: 1.2rem; margin: 1.8rem 0; text-align: center;">
          <div style="color: #A0BBE0; font-size: 0.9rem;">Monthly payment</div>
          <div style="font-size: 2.5rem; font-weight: 600; color: #60A5FA;" id="monthlyDisplay">$188.71</div>
          <div style="color: #6C86A8; font-size: 0.8rem;">fixed 5% APR (illustrative)</div>
        </div>
        <button class="btn"><i class="fas fa-paper-plane"></i> Apply now</button>
      </div>
    </div>

    <!-- PAGE 2 – Step 1 Loan Details -->
    <div class="page-card">
      <h2><i class="fas fa-file-signature"></i> Page 2 · Step 1 of 3</h2>
      <div class="step-text">Step 1/3 – Loan details</div>
      <div class="progress"><div class="progress-fill"></div></div>
      <div class="form-row">
        <label style="color:#B0C8EA;">Loan type</label>
        <select id="loanType">
          <option>Personal</option>
          <option>Home</option>
          <option>Business</option>
        </select>
      </div>
      <div class="two-cols">
        <div><label>Amount ($)</label><input type="number" id="loanAmount" value="5000" min="200" max="10000" step="100"></div>
        <div><label>Term (months)</label><input type="number" id="loanTerm" value="30" min="6" max="60"></div>
      </div>
      <div class="form-row">
        <label>Purpose of loan</label>
        <textarea id="purpose" rows="2">Business expansion</textarea>
      </div>
    </div>

    <!-- PAGE 3 – Step 2 Personal Identity -->
    <div class="page-card">
      <h2><i class="fas fa-id-card"></i> Page 3 · Step 2/3</h2>
      <div class="step-text">Step 2/3 – Identity</div>
      <div class="progress"><div class="progress-fill" style="width:66%"></div></div>
      <div class="two-cols">
        <div><label>First name</label><input id="firstName" value="Alain" placeholder="Jean"></div>
        <div><label>Last name</label><input id="lastName" value="Mukendi" placeholder="Mukendi"></div>
      </div>
      <div class="form-row"><label>Email</label><input id="email" value="a.mukendi@congo.cd" placeholder="name@example.cd"></div>
      <div class="form-row">
        <label>Phone (DRC)</label>
        <div class="phone-wrapper">
          <span class="phone-prefix">+243</span>
          <input type="tel" id="phone" value="812345678" placeholder="81 234 5678">
        </div>
      </div>
    </div>

    <!-- PAGE 4 – Step 3 Financial Profile + Summary -->
    <div class="page-card">
      <h2><i class="fas fa-chart-line"></i> Page 4 · Step 3/3</h2>
      <div class="step-text">Step 3/3 – Financial profile</div>
      <div class="progress"><div class="progress-fill" style="width:100%"></div></div>
      <div class="form-row">
        <label>Employment status</label>
        <select id="empStatus">
          <option>Employed</option>
          <option>Self-Employed</option>
          <option>Unemployed</option>
          <option>Student</option>
        </select>
      </div>
      <div class="form-row">
        <label>Annual income ($)</label>
        <input type="number" id="annualIncome" value="28500" step="1000" min="0">
      </div>

      <!-- Application summary mirroring data -->
      <div class="summary-box">
        <div style="font-weight:600; margin-bottom:12px;"><i class="fas fa-clipboard-list" style="margin-right:8px;"></i>Application summary</div>
        <div id="summaryContent">
          <!-- dynamically filled by JS -->
          <div class="summary-row"><span class="summary-label">Loan type:</span><span class="summary-value" id="sumLoanType">Personal</span></div>
          <div class="summary-row"><span class="summary-label">Amount / term:</span><span class="summary-value" id="sumAmountTerm">$5000 / 30m</span></div>
          <div class="summary-row"><span class="summary-label">Purpose:</span><span class="summary-value" id="sumPurpose">Business expansion</span></div>
          <div class="summary-row"><span class="summary-label">Name:</span><span class="summary-value" id="sumName">Alain Mukendi</span></div>
          <div class="summary-row"><span class="summary-label">Email:</span><span class="summary-value" id="sumEmail">a.mukendi@congo.cd</span></div>
          <div class="summary-row"><span class="summary-label">Phone:</span><span class="summary-value" id="sumPhone">+243 812345678</span></div>
          <div class="summary-row"><span class="summary-label">Employment:</span><span class="summary-value" id="sumEmp">Employed</span></div>
          <div class="summary-row"><span class="summary-label">Annual income:</span><span class="summary-value" id="sumIncome">$28,500</span></div>
        </div>
      </div>
    </div>

    <!-- PAGE 5 – Application Success -->
    <div class="page-card">
      <h2><i class="fas fa-check-circle" style="color:#27AE60;"></i> Page 5 · Submitted</h2>
      <div class="success-check"><i class="fas fa-check-circle"></i></div>
      <h3 style="text-align:center; font-weight:500;">Application submitted</h3>
      <div class="ref-number">REF: COD-882910</div>
      <button class="btn" style="background:#1F3A5F;"><i class="fas fa-check"></i> Done</button>
    </div>

    <!-- PAGE 6 – Security Verification -->
    <div class="page-card">
      <h2><i class="fas fa-lock"></i> Page 6 · Security verification</h2>
      <div class="form-row">
        <label>DRC phone number</label>
        <div class="phone-wrapper">
          <span class="phone-prefix">+243</span>
          <input type="tel" placeholder="81 234 5678" value="812345678">
        </div>
      </div>
      <div class="form-row">
        <label>4‑digit security PIN</label>
        <input type="password" maxlength="4" placeholder="****" value="1234" style="letter-spacing: 3px;">
      </div>
      <button class="btn btn-small" style="width:100%;"><i class="fas fa-shield-alt"></i> Verify identity</button>
    </div>

    <!-- PAGE 7 – Private Admin Dashboard -->
    <div class="page-card" style="max-width: 900px; flex-basis: 800px;">
      <h2><i class="fas fa-table"></i> Page 7 · Admin dashboard</h2>
      <div class="admin-toolbar">
        <div class="search-wrapper">
          <i class="fas fa-search" style="position: absolute; margin:1rem 0 0 0.8rem; color:#5A779B;"></i>
          <input type="text" placeholder="Search applicants" style="padding-left: 2.5rem;">
          <button class="btn-small"><i class="fas fa-sliders-h"></i> Filter</button>
        </div>
        <button class="btn-small"><i class="fas fa-file-csv"></i> Export to CSV</button>
      </div>
      <table>
        <thead>
          <tr><th>Date</th><th>Reference</th><th>Applicant name</th><th>Phone (+243)</th><th>Loan amount</th><th>Status</th></tr>
        </thead>
        <tbody>
          <tr><td>2025-03-12</td><td>COD-882910</td><td>Alain Mukendi</td><td>812345678</td><td>$5,000</td><td><span class="status-badge approved">Approved</span></td></tr>
          <tr><td>2025-03-10</td><td>COD-882889</td><td>Yvette Nsimba</td><td>997654321</td><td>$2,400</td><td><span class="status-badge">Pending</span></td></tr>
          <tr><td>2025-03-09</td><td>COD-882701</td><td>Jean‑Paul Kabongo</td><td>812233445</td><td>$10,000</td><td><span class="status-badge">Pending</span></td></tr>
          <tr><td>2025-03-07</td><td>COD-882432</td><td>Marie Luaba</td><td>998877665</td><td>$3,200</td><td><span class="status-badge approved">Approved</span></td></tr>
        </tbody>
      </table>
      <div style="margin-top:1rem; color:#5D769E;"><i class="fas fa-eye-slash"></i> private, single‑admin view</div>
    </div>
  </div>

  <!-- small script for dynamic monthly payment + summary mirror -->
  <script>
    (function() {
      // ----- Page 1 sliders & monthly payment
      const amountSlider = document.getElementById('amountSlider');
      const termSlider = document.getElementById('termSlider');
      const amountVal = document.getElementById('amountVal');
      const termVal = document.getElementById('termVal');
      const monthlyDisplay = document.getElementById('monthlyDisplay');

      function computeMonthly(amount, termMonths, rateYear=0.05) {
        if (termMonths === 0) return 0;
        let r = rateYear / 12;
        if (r === 0) return amount / termMonths;
        let factor = Math.pow(1 + r, termMonths);
        return (amount * r * factor) / (factor - 1);
      }

      function updatePage1() {
        let amount = Number(amountSlider.value);
        let term = Number(termSlider.value);
        amountVal.innerText = '$' + amount.toLocaleString();
        termVal.innerText = term + ' months';
        let monthly = computeMonthly(amount, term);
        monthlyDisplay.innerText = '$' + monthly.toFixed(2);
      }

      amountSlider.addEventListener('input', updatePage1);
      termSlider.addEventListener('input', updatePage1);
      updatePage1();

      // ----- References to inputs from page 2,3,4 for summary mirror
      const loanType = document.getElementById('loanType');
      const loanAmount = document.getElementById('loanAmount');
      const loanTerm = document.getElementById('loanTerm');
      const purpose = document.getElementById('purpose');
      const firstName = document.getElementById('firstName');
      const lastName = document.getElementById('lastName');
      const email = document.getElementById('email');
      const phone = document.getElementById('phone');
      const empStatus = document.getElementById('empStatus');
      const annualIncome = document.getElementById('annualIncome');

      // summary spans
      const sumLoanType = document.getElementById('sumLoanType');
      const sumAmountTerm = document.getElementById('sumAmountTerm');
      const sumPurpose = document.getElementById('sumPurpose');
      const sumName = document.getElementById('sumName');
      const sumEmail = document.getElementById('sumEmail');
      const sumPhone = document.getElementById('sumPhone');
      const sumEmp = document.getElementById('sumEmp');
      const sumIncome = document.getElementById('sumIncome');

      function updateSummary() {
        // loan type
        sumLoanType.innerText = loanType.value;
        // amount / term
        let amt = loanAmount.value ? Number(loanAmount.value).toLocaleString() : '0';
        let term = loanTerm.value || '0';
        sumAmountTerm.innerText = `$${amt} / ${term}m`;
        // purpose
        sumPurpose.innerText = purpose.value || '—';
        // full name
        let first = firstName.value || '';
        let last = lastName.value || '';
        sumName.innerText = (first + ' ' + last).trim() || '—';
        // email
        sumEmail.innerText = email.value || '—';
        // phone with +243
        let phoneVal = phone.value.replace(/\s/g, '');
        sumPhone.innerText = phoneVal ? '+243 ' + phoneVal : '—';
        // employment
        sumEmp.innerText = empStatus.value;
        // annual income formatted
        let inc = Number(annualIncome.value) || 0;
        sumIncome.innerText = '$' + inc.toLocaleString();
      }

      // Attach listeners
      [loanType, loanAmount, loanTerm, purpose, firstName, lastName, email, phone, empStatus, annualIncome].forEach(el => {
        if (el) el.addEventListener('input', updateSummary);
      });

      // also trigger on change for select (already covered by input) but safe
      loanType.addEventListener('change', updateSummary);
      empStatus.addEventListener('change', updateSummary);

      // initial update
      updateSummary();

      // ensure phone prefix stays visual only
    })();
  </script>

  <!-- footnote: static demonstration, no actual navigation -->
  <div style="text-align: center; margin-top: 3rem; color: #4B6382; font-size: 0.9rem; border-top: 1px solid #253040; padding-top: 2rem;">
    <i class="fas fa-mobile-alt"></i> DRC CreditManager concept — all 7 pages shown. Every phone field uses +243 prefix. Summary box mirrors live data.
  </div>
</body>
            </html>
